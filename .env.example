# Application
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
APP_VERSION=0.1.0
PORT=4000
API_GLOBAL_PREFIX=api/v1
API_CORS_ORIGINS=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://livechat:livechat@localhost:5432/livechat?schema=public
DATABASE_CONNECT_ON_STARTUP=false

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=livechat-saas-api
JWT_AUDIENCE=livechat-saas
AUTH_REFRESH_COOKIE_NAME=lc_refresh_token
AUTH_COOKIE_SECURE=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="LiveChat SaaS <no-reply@example.com>"

# File storage
FILE_STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Realtime
SOCKET_IO_CORS_ORIGIN=http://localhost:3000
